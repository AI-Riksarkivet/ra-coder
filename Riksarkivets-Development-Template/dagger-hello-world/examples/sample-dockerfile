# Sample Dockerfile for testing Dagger builds
# This demonstrates the Docker-free building capability

FROM python:3.12-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python ML libraries
RUN pip install --no-cache-dir \
    numpy \
    pandas \
    scikit-learn \
    matplotlib \
    seaborn

# Create app directory
WORKDIR /app

# Copy application files
COPY . .

# Default command
CMD ["python", "-c", "print('🚀 Hello from Docker-free Kaniko build!')"]