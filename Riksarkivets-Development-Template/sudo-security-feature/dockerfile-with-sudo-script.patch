# Dockerfile Enhancement - Add Secure Sudo Management
# Add this after the user creation section (around line 28)

# Copy security scripts and create secure sudo configuration
COPY request-sudo-access.sh /usr/local/bin/request-sudo-access
COPY secure-sudo-simple.sh /usr/local/bin/configure-secure-sudo
RUN chmod +x /usr/local/bin/request-sudo-access /usr/local/bin/configure-secure-sudo && \
    # Replace the insecure sudo configuration (line 26-27):
    # OLD: echo "coder ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/nopasswd && \
    # NEW: Create secure sudo configuration
    cat > /etc/sudoers.d/coder-restricted << 'EOF' && \
# Secure sudo configuration for ML development workspace
# Package management
coder ALL=(ALL) NOPASSWD: /usr/bin/apt-get, /usr/bin/apt, /usr/bin/dpkg
coder ALL=(ALL) NOPASSWD: /usr/bin/pip, /usr/bin/pip3, /usr/local/bin/uv
coder ALL=(ALL) NOPASSWD: /home/linuxbrew/.linuxbrew/bin/brew
# System monitoring
coder ALL=(ALL) NOPASSWD: /usr/bin/nvidia-smi
# File operations in safe directories
coder ALL=(ALL) NOPASSWD: /bin/mkdir, /bin/chown, /bin/chmod
EOF
    chmod 440 /etc/sudoers.d/coder-restricted && \
    # Install 'at' command for temporary access scheduling
    apt-get update && apt-get install -y --no-install-recommends at && \
    systemctl enable atd && \
    rm -rf /var/lib/apt/lists/*

# Create helpful aliases and documentation
RUN echo 'alias sudo-help="request-sudo-access"' >> /home/coder/.bashrc && \
    echo 'alias sudo-status="sudo -l"' >> /home/coder/.bashrc